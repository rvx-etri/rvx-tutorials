<?xml version="1.0" ?>
<rvx>
  <dec_ip>
    <name>sdram</name>
    <hdl_name>ERVP_SDRAM</hdl_name>
    <def_parameter>
      <name>BW_ADDR</name>
      <value>32</value>
    </def_parameter>
    <def_parameter>
      <name>BW_DATA</name>
      <value>32</value>
    </def_parameter>
    <def_parameter>
      <name>CAPACITY</name>
      <value>0x08000000</value>
    </def_parameter>
    <def_parameter>
      <name>MEMORYMAP_SIZE</name>
      <value>CAPACITY</value>
    </def_parameter>

    <imp_dependent/>

    <signal>
      <name>rstnn</name>
      <width>1</width>
      <port>input</port>
    </signal>

    <reset_property>
      <id>rstnn</id>
      <type>asynch</type>
      <type>negative</type>
      <group>1</group>
    </reset_property>

    <signal>
      <name>clk</name>
      <width>1</width>
      <port>input</port>
      <comm_type>clk_sdram</comm_type>
    </signal>

    <signal>
			<name>global_rstnn</name>
			<width>1</width>
			<port>input</port>
			<comm_type>global_rstnn</comm_type>
		</signal>

    <interface>
      <name>no_name</name>
      <library_name>ahbs</library_name>
      <hdl_prefix></hdl_prefix>
      <role>receiver</role>
      <comm_type>memory:data_c</comm_type>
      <memorymap>
        <size>MEMORYMAP_SIZE</size>
      </memorymap>
      <parameter>
        <id>bw_addr</id>
        <value>BW_ADDR</value>
      </parameter>
      <parameter>
        <id>bw_data</id>
        <value>32</value>
      </parameter>
      <sync>clk</sync>
      <init>rstnn</init>
    </interface>

    <interface>
      <name>ctrl</name>
      <library_name>apb</library_name>
      <role>receiver</role>
      <comm_type>memory:all</comm_type>
      <memorymap>
        <size>0x1000</size>
      </memorymap>
      <parameter>
        <id>bw_addr</id>
        <value>BW_ADDR</value>
      </parameter>
      <parameter>
        <id>bw_data</id>
        <value>32</value>
      </parameter>
      <sync>clk</sync>
      <init>rstnn</init>
    </interface>

    <tristate>
      <name>LPSDR_DQ</name>
      <library_name>tristate_od</library_name>
      <role>sender</role>
      <comm_type>external</comm_type>
      <parameter>
        <id>bw_data</id>
        <value>32</value>
      </parameter>
      <sync>None</sync>
      <init>None</init>
    </tristate>

    <signal>
      <name>LPSDR_DQ_sod_byte</name>
      <width>4</width>
      <port>output</port>
    </signal>

    <signal>
      <name>LPSDR_DQ_soe_byte</name>
      <width>4</width>
      <port>output</port>
    </signal>

    <included_port>sdram_cell</included_port>
  </dec_ip>
</rvx>
